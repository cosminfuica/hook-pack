{
  "name": "hook-pack",
  "version": "0.1.0",
  "description": "Native Claude Code hook foundation with modular enablement controls.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run bundle:runtime",
    "bundle:runtime": "node scripts/bundle-runtime.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test \"dist/tests/**/*.test.js\"",
    "validate:plugin": "npm run build && node scripts/validate-plugin.mjs"
  },
  "dependencies": {
    "picomatch": "^4.0.0",
    "tar": "^7.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/picomatch": "^3.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.3"
  }
}
